{
  "name": "morse-blog",
  "private": true,
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "dev:demo": "turbo dev --filter=@morse/demo",
    "dev:clean": "turbo dev --filter=@morse/clean",
    "dev:editorial": "turbo dev --filter=@morse/editorial",
    "dev:magazine": "turbo dev --filter=@morse/magazine",
    "dev:minimal": "turbo dev --filter=@morse/minimal"
  },
  "packageManager": "npm@11.6.2",
  "devDependencies": {
    "turbo": "^2"
  }
}
